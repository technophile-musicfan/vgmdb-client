# vgmdb-client — environment configuration
#
# Copy this file to `.env` and fill in your values:
#     cp example.env .env
# `.env` is git-ignored — never commit your real token.
#
# These are needed to fetch live vgmdb.net pages (e.g. to capture M5 fixtures),
# because vgmdb.net sits behind Cloudflare and exposes no API. They map onto the
# transport's TransportConfig fields.

# REQUIRED. A valid Cloudflare clearance cookie for vgmdb.net.
# Get it from your browser's cookies for vgmdb.net (the `cf_clearance` value)
# after passing the Cloudflare challenge. Tokens are short-lived — refresh when
# requests start returning a Cloudflare challenge.
VGMDB_CF_CLEARANCE=

# REQUIRED. The User-Agent string. It MUST match the browser the cf_clearance
# cookie was issued for; a mismatched User-Agent invalidates the token.
VGMDB_USER_AGENT=

# OPTIONAL. Override the vgmdb base URL. Defaults to https://vgmdb.net.
# VGMDB_BASE_URL=https://vgmdb.net
